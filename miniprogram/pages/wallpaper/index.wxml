<view class="page-container">
  <view class="content-wrapper">
    <!-- 筛选栏 -->
    <scroll-view class="filter-bar" scroll-x enable-flex>
      <view 
        class="filter-item {{!currentBrandId ? 'active' : ''}}"
        bindtap="onFilterTap"
        data-id=""
      >全部</view>
      <view 
        class="filter-item {{currentBrandId === item._id ? 'active' : ''}}"
        wx:for="{{brands}}"
        wx:key="_id"
        bindtap="onFilterTap"
        data-id="{{item._id}}"
      >{{item.name}}</view>
    </scroll-view>
    
    <!-- 加载状态 - 骨架屏 -->
    <skeleton wx:if="{{loading && list.length === 0}}" type="grid" count="6" />
    
    <!-- 错误状态 -->
    <error wx:elif="{{error && list.length === 0}}" bind:retry="loadData" />
    
    <!-- 空状态 -->
    <empty wx:elif="{{!loading && list.length === 0}}" title="暂无壁纸" />
    
    <!-- 壁纸列表 -->
    <view wx:else class="wallpaper-grid">
      <view 
        class="wallpaper-item"
        wx:for="{{list}}"
        wx:key="_id"
        bindtap="onItemTap"
        data-id="{{item._id}}"
      >
        <image 
          class="wallpaper-image" 
          src="{{item.coverUrl}}" 
          mode="aspectFill"
          lazy-load
        />
        <view class="wallpaper-info">
          <text class="wallpaper-title">{{item.title}}</text>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{list.length > 0}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">没有更多了</text>
    </view>
  </view>
  
  <tab-bar currentTab="pages/wallpaper/index" />
</view>
