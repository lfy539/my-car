<view class="page-container">
  <loading wx:if="{{loading}}" fullscreen text="加载中..." />
  
  <view wx:else class="detail-content">
    <!-- 封面区域 -->
    <view class="cover-area">
      <image class="cover-image" src="{{sound.coverUrl}}" mode="aspectFill" />
      <view class="play-overlay" bindtap="onPlayToggle">
        <view class="play-btn {{isPlaying ? 'playing' : ''}}">
          <text>{{isPlaying ? '⏸' : '▶'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 播放进度 -->
    <view class="player-bar">
      <text class="time-text">{{formatTime(currentTime)}}</text>
      <slider 
        class="progress-slider"
        value="{{progress}}"
        max="100"
        block-size="12"
        activeColor="#2F81F7"
        backgroundColor="#30363D"
        bindchange="onSeek"
      />
      <text class="time-text">{{formatTime(duration)}}</text>
    </view>
    
    <!-- 音效信息 -->
    <view class="info-card">
      <text class="sound-title">{{sound.title}}</text>
      <view class="info-row">
        <text class="info-label">类型</text>
        <text class="info-value">{{sound.soundType}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">时长</text>
        <text class="info-value">{{sound.duration}}秒</text>
      </view>
      <view class="info-row">
        <text class="info-label">品牌</text>
        <text class="info-value">{{brandName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">音质</text>
        <text class="info-value">{{sound.bitrate}}kbps</text>
      </view>
    </view>
    
    <!-- 相似推荐 -->
    <view class="recommend-section" wx:if="{{similarList.length > 0}}">
      <text class="section-title">相似推荐</text>
      <view class="recommend-list">
        <view 
          class="recommend-item"
          wx:for="{{similarList}}"
          wx:key="_id"
          bindtap="onSimilarTap"
          data-id="{{item._id}}"
        >
          <image class="recommend-cover" src="{{item.coverUrl}}" mode="aspectFill" />
          <view class="recommend-info">
            <text class="recommend-title">{{item.title}}</text>
            <text class="recommend-meta">{{item.soundType}} · {{item.duration}}s</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="action-btn {{isFavorite ? 'active' : ''}}" bindtap="onToggleFavorite">
        <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
        <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-btn primary" bindtap="onDownload">
        <text class="action-icon">📥</text>
        <text class="action-text">下载音效</text>
      </view>
      <view class="action-btn" bindtap="onShare">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </view>
    </view>
  </view>
</view>

<wxs module="formatTime">
module.exports = function(seconds) {
  if (!seconds || seconds < 0) return '0:00';
  var mins = Math.floor(seconds / 60);
  var secs = Math.floor(seconds % 60);
  return mins + ':' + (secs < 10 ? '0' : '') + secs;
}
</wxs>
